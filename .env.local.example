# ===========================================
# Dárkee.cz — Environment Variables
# ===========================================
# Zkopíruj tento soubor jako .env.local a vyplň hodnoty

# --- Databáze (PostgreSQL) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/darkee?schema=public"

# --- NextAuth ---
NEXTAUTH_SECRET="change-this-to-a-random-secret-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# --- AI (volitelné — pro budoucí AI doporučení) ---
ANTHROPIC_API_KEY=""

# --- Analytics (volitelné) ---
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.posthog.com"

# --- Affiliate sítě (volitelné) ---
EHUB_API_KEY=""
AFILKA_PUBLISHER_ID=""

# --- Aplikace ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
MERCHANT_AUTO_APPROVE="false"
